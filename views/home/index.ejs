<section class="home-hero reveal">
  <div class="container">
    <h1>ImperialPaws Pekingese</h1>

    <p class="hero-subtitle">
      Ethical, responsible Pekingese breeding focused on health,
      temperament, and lifelong placement.
    </p>

    <a class="btn-primary" href="/puppies">View Available Puppies</a>

    <p class="hero-trust">
      Home-raised &bull; Thoughtful placement &bull; Ongoing support
    </p>
  </div>
</section>

<section class="home-trust-strip" aria-label="ImperialPaws trust signals">
  <div class="container trust-grid">
    <div>
      <strong>Application Before Payment</strong>
      <span>No public payment requests before review and approval.</span>
    </div>
    <div>
      <strong>Status Tracking</strong>
      <span>Every application receives a private tracking code.</span>
    </div>
    <div>
      <strong>Clear Invoices</strong>
      <span>Approved buyers receive itemized adoption invoices.</span>
    </div>
    <div>
      <strong>USA Families</strong>
      <span>Built for thoughtful placement across the United States.</span>
    </div>
  </div>
</section>

<section class="home-section reveal">
  <div class="container narrow">
    <p class="intro-text">
      ImperialPaws is a dedicated Pekingese breeding program committed to
      raising healthy, well-socialized puppies in a calm home environment.
      Every placement is handled with care, transparency, and long-term
      responsibility.
    </p>

    <p class="intro-text">
      Our focus is not volume or speed. It is the right puppy, the right family,
      and a process that protects both.
    </p>

    <div class="trust-panel">
      <h2>Built Around Buyer Confidence</h2>
      <ul class="trust-list">
        <li>Puppy details, status updates, application review, and invoices stay organized in one secure workflow.</li>
        <li>No payment request is presented to public visitors before review and approval.</li>
        <li>Approved families receive clear next steps and a written adoption invoice for their records.</li>
      </ul>
    </div>
  </div>
</section>

<% if (featuredPuppies && featuredPuppies.length) { %>
  <section class="home-featured-lux reveal">
    <div class="container">
      <header class="featured-header">
        <h2>Featured Puppies</h2>
        <p>
          A small selection of currently available Pekingese puppies,
          raised with care, transparency, and intention.
        </p>
      </header>

      <div class="featured-grid">
        <% featuredPuppies.forEach(puppy => { %>
          <article class="featured-card">
            <div class="featured-image">
              <% if (puppy.images && puppy.images.length) { %>
                <img
                  src="<%= puppy.images.find(i => i.isCover)?.path || puppy.images[0].path %>"
                  alt="<%= puppy.name %>"
                  loading="lazy"
                  decoding="async">
              <% } else { %>
                <div class="image-placeholder">No Image</div>
              <% } %>

              <span class="featured-status <%= statusClass(puppy.status) %>">
                <%= puppy.status || "Available" %>
              </span>
            </div>

            <div class="featured-body">
              <h3><%= puppy.name %></h3>

              <p class="meta">
                <%= puppy.gender || "-" %>
                <% if (puppy.color) { %> &bull; <%= puppy.color %><% } %>
              </p>

              <% if (puppy.price) { %>
                <div class="price">
                  <%= currencySymbol(puppy.currency) %><%= Number(puppy.price).toFixed(2) %>
                </div>
              <% } %>

              <a href="/puppies/<%= puppy.id %>" class="btn-secondary">
                View Details
              </a>
            </div>
          </article>
        <% }) %>
      </div>

      <div class="featured-footer">
        <a href="/puppies" class="text-link">View all available puppies</a>
      </div>
    </div>
  </section>
<% } %>

<section class="home-section reveal">
  <div class="container narrow">
    <h2>Responsible Placement</h2>

    <p>
      ImperialPaws does not operate as a marketplace or broker. Puppies are not
      placed based on speed, bidding, or payment alone. Each adoption is reviewed
      carefully with the welfare of the puppy as the priority.
    </p>

    <p>
      Families can browse puppies, submit an application, track status, and
      receive a clear invoice only after approval.
    </p>
  </div>
</section>

<section class="home-highlight reveal">
  <div class="container narrow">
    <p>
      Responsible breeding is more than producing puppies. It is planning, care,
      documentation, and ethical decision-making from first inquiry through
      lifelong support.
    </p>
  </div>
</section>

<section class="home-section reveal">
  <div class="container narrow">
    <h2>Our Commitment</h2>
    <p>
      Puppies are raised in a home environment with daily interaction, early
      socialization, appropriate veterinary care, and careful monitoring before
      placement.
    </p>
    <p class="center">
      <a class="text-link" href="/about">Learn more about us</a>
    </p>
  </div>
</section>

<section class="home-section reveal home-alt">
  <div class="container">
    <h2>Why Families Choose ImperialPaws</h2>

    <div class="feature-grid">
      <div class="feature">
        <h3>Ethical Breeding</h3>
        <p>
          We prioritize health, temperament, and responsible standards over
          production volume or trends.
        </p>
      </div>

      <div class="feature">
        <h3>Transparent Process</h3>
        <p>
          Applications, tracking, approval steps, and invoices are handled in
          one organized system.
        </p>
      </div>

      <div class="feature">
        <h3>Home-Raised Puppies</h3>
        <p>
          Puppies receive daily care, structure, and early socialization before
          joining approved homes.
        </p>
      </div>
    </div>

    <div class="assurance-grid">
      <div class="assurance-card">
        <strong>Private Tracking</strong>
        <p>Applicants receive a code to check status without exposing private details publicly.</p>
      </div>
      <div class="assurance-card">
        <strong>Careful Review</strong>
        <p>Placement decisions consider the puppy's welfare, buyer preparedness, and fit.</p>
      </div>
      <div class="assurance-card">
        <strong>Invoice Records</strong>
        <p>Invoices are created only after approval and remain accessible through the buyer's tracking flow.</p>
      </div>
    </div>
  </div>
</section>

<section class="home-section reveal">
  <div class="container narrow">
    <h2>Adoption Steps</h2>

    <div class="expect-grid">
      <div>
        <h3>Browse</h3>
        <p>Review available puppies and detailed profiles at your own pace.</p>
      </div>

      <div>
        <h3>Apply</h3>
        <p>Submit one application per puppy so placement can be reviewed fairly.</p>
      </div>

      <div>
        <h3>Track</h3>
        <p>Use your tracking code for status updates and next steps.</p>
      </div>
    </div>

    <p class="center">
      <a class="text-link" href="/adoption-process">View the full adoption process</a>
    </p>
  </div>
</section>

<section class="home-section reveal home-alt">
  <div class="container narrow">
    <h2>Questions Before Applying?</h2>
    <p>
      The FAQ page explains availability, applications, approval, payments,
      puppy care, and what families can expect from the process.
    </p>
    <p class="center">
      <a class="text-link" href="/faq">Read frequently asked questions</a>
    </p>
  </div>
</section>

<section class="home-section reveal">
  <div class="container narrow">
    <h2>Buyer Safety Notes</h2>
    <p>
      Responsible puppy placement should never feel rushed. Review each puppy
      profile carefully, submit one accurate application, and keep your tracking
      code private. Any invoice should match the approved puppy, buyer details,
      and agreed adoption amount.
    </p>
    <p class="center">
      <a class="text-link" href="/privacy-policy">Review privacy policy</a>
      <span class="divider">&bull;</span>
      <a class="text-link" href="/terms">Read website terms</a>
    </p>
  </div>
</section>

<% if (testimonials && testimonials.length) { %>
  <section class="home-testimonials-lux reveal">
    <div class="container">
      <header class="testimonials-header">
        <h2>What Puppy Families Say</h2>
        <p>
          Thoughtful words shared by families who welcomed an ImperialPaws
          Pekingese into their home.
        </p>
      </header>

      <div class="testimonials-grid">
        <% testimonials.forEach(t => { %>
          <article class="testimonial-card">
            <p class="testimonial-message">&ldquo;<%= t.message %>&rdquo;</p>
            <div class="testimonial-author">
              <strong><%= t.name %></strong>
              <% if (t.location) { %>
                <span><%= t.location %></span>
              <% } %>
            </div>
          </article>
        <% }) %>
      </div>

      <div class="testimonials-footer">
        <a href="/testimonials" class="text-link">Read more testimonials</a>
        <span class="divider">&bull;</span>
        <a href="/testimonials/submit" class="text-link">Share your experience</a>
      </div>
    </div>
  </section>
<% } %>
