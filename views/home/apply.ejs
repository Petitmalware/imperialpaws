<div class="page-application">

  <section class="page-hero reveal">
    <div class="container">
      <h1>Adoption Application</h1>
      <p class="subtitle">
        Apply for <strong><%= puppy.name %></strong> through a careful review
        process built around responsible placement.
      </p>
    </div>
  </section>

  <section class="page-content reveal">
    <div class="container narrow">

      <% const formValues = typeof values !== "undefined" ? values : {}; %>

      <% if (typeof error !== "undefined" && error) { %>
        <div class="error-box"><%= error %></div>
      <% } %>

      <div class="notice-box">
        <p>
          No payment is requested by this form. If your application is approved,
          you will receive clear next steps and any invoice will be tied to your
          private tracking code.
        </p>
      </div>

      <form method="POST" action="/apply" class="application-form">

        <input type="hidden" name="puppyId" value="<%= puppy.id %>">

        <div class="form-group">
          <label>Full Name</label>
          <input type="text" name="name" value="<%= formValues.name || '' %>" required>
        </div>

        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" value="<%= formValues.email || '' %>" required>
        </div>

        <div class="form-group">
          <label>Phone</label>
          <input type="text" name="phone" value="<%= formValues.phone || '' %>" required>
        </div>

        <div class="form-group">
          <label>Location</label>
          <input type="text" name="location" value="<%= formValues.location || '' %>" required>
        </div>

        <div class="form-group">
          <label>Message</label>
          <textarea
            name="message"
            rows="5"
            placeholder="Tell us about your household and experience with dogs or the breed">
<%= formValues.message || '' %></textarea>
        </div>

        <button class="btn-primary" type="submit">
          Submit Application
        </button>

      </form>

      <div class="application-notes">

        <p class="note-strong">
          No payments are requested or accepted until an application has been
          reviewed and approved.
        </p>

        <p>
          Submitting an adoption application allows us to learn more about you
          and determine whether this puppy is the right fit for your home.
        </p>

        <p>
          Submitting an application does not guarantee approval.
          Our goal is thoughtful, responsible placement rather than rushed decisions.
        </p>

      </div>

      <div class="trust-panel">
        <h2>What Happens After Submission</h2>
        <ul class="trust-list">
          <li>You receive a tracking code for this application.</li>
          <li>We review your information and may follow up if more context is needed.</li>
          <li>If you already applied for this puppy with the same email or phone, the site will reuse your original tracking code.</li>
          <li>Approved buyers can receive a clear invoice through the tracking flow.</li>
        </ul>
      </div>

    </div>
  </section>

</div>
