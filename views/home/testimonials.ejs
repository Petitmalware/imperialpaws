<section class="page-hero reveal">
  <div class="container">
    <h1>Adopter Experiences</h1>
    <p class="subtitle">
      Real stories and reviews from ImperialPaws Pekingese puppy families across the country.
    </p>
  </div>
</section>

<section class="page-content reveal">
  <div class="container">

    <% if (!testimonials.length) { %>
      <p class="center">No testimonials published yet. Be the first to share your experience!</p>
    <% } else { %>

      <div class="testimonials-lux-grid" style="display:grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap:2rem;">

        <% testimonials.forEach(t => { %>
          <article class="testimonial-card" style="background:#fffdf9; border:1px solid #e8e4dc; border-radius:14px; padding:1.8rem; box-shadow:0 8px 24px rgba(0,0,0,0.05); display:flex; flex-direction:column; justify-content:space-between;">

            <div>
              <div style="color:#c7a45a; font-size:1rem; margin-bottom:0.6rem;">
                <% const stars = Number(t.rating) || 5; %>
                <%= "★".repeat(stars) %><%= "☆".repeat(5 - stars) %>
              </div>

              <% if (t.photoUrl) { %>
                <div style="width:100%; height:180px; border-radius:10px; overflow:hidden; margin-bottom:1rem; background:#eee;">
                  <img src="<%= t.photoUrl %>" alt="Pekingese puppy" style="width:100%; height:100%; object-fit:cover;">
                </div>
              <% } %>

              <p class="testimonial-message" style="font-size:0.98rem; line-height:1.7; color:#333; margin-bottom:1.2rem; font-style:italic;">
                &ldquo;<%= t.message %>&rdquo;
              </p>
            </div>

            <div class="testimonial-author" style="border-top:1px solid #eee; padding-top:0.8rem; font-size:0.88rem; color:#555;">
              <strong><%= t.name %></strong>
              <% if (t.location) { %>
                <span> &bull; <%= t.location %></span>
              <% } %>
              <% if (t.puppyName) { %>
                <div style="font-size:0.8rem; color:#7a5c1e; margin-top:2px;">
                  🐾 Parent of <strong><%= t.puppyName %></strong>
                </div>
              <% } %>
            </div>

          </article>
        <% }) %>

      </div>

    <% } %>

    <div class="trust-panel" style="margin-top:3rem;">
      <h2>Verified Reviews & Moderation</h2>
      <p>
        Every ImperialPaws review is submitted by actual adopters and moderated before appearing publicly to maintain authentic, trustworthy feedback.
      </p>
    </div>

    <div class="center testimonials-submit-link" style="margin-top:2rem;">
      <a href="/testimonials/submit" class="btn-primary">
        + Share Your Experience
      </a>
    </div>

  </div>
</section>
