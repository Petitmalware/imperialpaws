<section class="page-hero reveal">
  <div class="container">
    <h1>Testimonials</h1>
    <p class="subtitle">
      Experiences shared by ImperialPaws puppy families and reviewed before
      appearing publicly.
    </p>
  </div>
</section>

<section class="page-content reveal">
  <div class="container">

    <% if (!testimonials.length) { %>
      <p class="center">No testimonials available yet.</p>
    <% } else { %>

      <div class="testimonials-lux-grid">

        <% testimonials.forEach(t => { %>
          <article class="testimonial-card">

            <p class="testimonial-message">
              &ldquo;<%= t.message %>&rdquo;
            </p>

            <div class="testimonial-author">
              <strong><%= t.name %></strong>
              <% if (t.location) { %>
                <span><%= t.location %></span>
              <% } %>
            </div>

          </article>
        <% }) %>

      </div>

    <% } %>

    <div class="trust-panel">
      <h2>Review Moderation</h2>
      <p>
        Public testimonials are reviewed before publication so the page stays
        relevant, respectful, and connected to real ImperialPaws experiences.
      </p>
    </div>

    <div class="center testimonials-submit-link">
      <a href="/testimonials/submit" class="btn-primary">
        Share Your Experience
      </a>
    </div>

  </div>
</section>
