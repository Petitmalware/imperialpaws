<div class="page-track reveal">

  <section class="page-hero reveal">
    <div class="container">
      <h1>Track Your Application</h1>

      <p class="track-intro reveal">
        Enter the tracking code you received after submitting your adoption
        application to view its current status.
      </p>

      <p class="track-note reveal">
        Keep your code private. Approved invoice links are shown only through
        the matching application status page.
      </p>
    </div>
  </section>

  <section class="page-content reveal">
    <div class="container narrow reveal">

      <% if (error) { %>
        <div class="error-box"><%= error %></div>
      <% } %>

      <form method="GET" action="/track/result" class="track-form">

        <% const trackingCode = typeof code !== "undefined" ? code : ""; %>

        <div class="form-group">
          <label>Tracking Code</label>
          <input type="text" name="code" value="<%= trackingCode %>" required>
        </div>

        <button class="btn-primary" type="submit">
          Check Status
        </button>

      </form>

      <div class="trust-panel">
        <h2>Status Guide</h2>
        <ul class="trust-list">
          <li><strong>Pending:</strong> your application is still being reviewed.</li>
          <li><strong>Approved:</strong> next steps may be available and an invoice can be created.</li>
          <li><strong>Rejected:</strong> this puppy will not move forward with this application.</li>
          <li><strong>Sold:</strong> final placement has been marked complete.</li>
        </ul>
      </div>

    </div>
  </section>

</div>
