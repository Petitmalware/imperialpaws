<div class="page-testimonial-submit reveal">

  <section class="page-hero reveal">
    <div class="container">
      <h1>Share Your Experience</h1>
      <p class="subtitle">
        Your feedback helps future families feel confident in our home-raised Pekingese.
      </p>
    </div>
  </section>

  <section class="page-content reveal">
    <div class="container narrow">

      <% const formValues = typeof values !== "undefined" ? values : {}; %>

      <% if (error) { %>
        <div class="error-box center"><%= error %></div>
      <% } %>

      <form method="post" action="/testimonials/submit" class="testimonial-form">

        <div class="form-group">
          <label>Your Name *</label>
          <input type="text" name="name" value="<%= formValues.name || '' %>" placeholder="e.g. Sarah M." required>
        </div>

        <div class="form-group">
          <label>Email Address *</label>
          <input type="email" name="email" value="<%= formValues.email || '' %>" placeholder="e.g. sarah@example.com" required>
        </div>

        <div class="form-grid" style="display:grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <div class="form-group">
            <label>City & State (optional)</label>
            <input type="text" name="location" value="<%= formValues.location || '' %>" placeholder="e.g. Austin, TX">
          </div>

          <div class="form-group">
            <label>Adopted Puppy Name (optional)</label>
            <input type="text" name="puppyName" value="<%= formValues.puppyName || '' %>" placeholder="e.g. Oliver / Duke">
          </div>
        </div>

        <div class="form-group">
          <label>Rating *</label>
          <select name="rating" style="width:100%; padding:0.75rem; border-radius:8px; border:1px solid #ccc; font-size:16px;">
            <option value="5" selected>⭐️⭐️⭐️⭐️⭐️ (5/5 Stars - Exceptional Experience)</option>
            <option value="4">⭐️⭐️⭐️⭐️ (4/5 Stars - Great Experience)</option>
            <option value="3">⭐️⭐️⭐️ (3/5 Stars - Average)</option>
          </select>
        </div>

        <div class="form-group">
          <label>Puppy Photo URL (optional)</label>
          <input type="url" name="photoUrl" value="<%= formValues.photoUrl || '' %>" placeholder="https://example.com/photo.jpg">
          <small style="color:#777; font-size:0.8rem; display:block; margin-top:-1rem; margin-bottom:1rem;">
            Link a photo of your grown ImperialPaws Pekingese!
          </small>
        </div>

        <div class="form-group">
          <label>Your Testimonial Experience *</label>
          <textarea name="message" rows="6" placeholder="Tell us about your experience adopting from ImperialPaws and how your puppy is doing..." required><%= formValues.message || '' %></textarea>
        </div>

        <button type="submit" class="btn-primary" style="width:100%;">
          Submit Verified Testimonial
        </button>

      </form>

    </div>
  </section>

</div>
