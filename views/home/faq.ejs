<section class="page-hero reveal">
  <div class="container">
    <h1>Frequently Asked Questions</h1>
    <p class="subtitle">
      Helpful information about our puppies and adoption process.
    </p>
  </div>
</section>

<section class="page-content reveal">
  <div class="container narrow faq reveal">
    <div class="notice-box">
      <p>
        The safest path is simple: review the puppy profile, submit one accurate
        application, wait for approval, and only then review any invoice tied to
        your private tracking code.
      </p>
    </div>

    <% faqItems.forEach(item => { %>
      <h2><%= item.question %></h2>
      <p><%= item.answer %></p>
    <% }) %>
  </div>
</section>
