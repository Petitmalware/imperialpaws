<section class="page-hero reveal">
  <div class="container">
    <h1>Frequently Asked Questions</h1>
    <p class="subtitle">
      Helpful information about our puppies and adoption process.
    </p>
  </div>
</section>

<section class="page-content reveal">
  <div class="container narrow faq reveal">
    <% faqItems.forEach(item => { %>
      <h2><%= item.question %></h2>
      <p><%= item.answer %></p>
    <% }) %>
  </div>
</section>
