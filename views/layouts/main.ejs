<!DOCTYPE html>
<html lang="en">
<head>
  <%
    const fallbackTitle = typeof title !== "undefined" ? title : "ImperialPaws Pekingese";
    const meta = typeof pageMeta !== "undefined" ? pageMeta : {};
    const metaTitle = meta.title || fallbackTitle;
    const metaDescription = meta.description || "ImperialPaws Pekingese is a responsible Pekingese breeder focused on thoughtful placement, buyer applications, status tracking, and clear adoption invoices.";
    const metaRobots = isAdminPage ? "noindex, nofollow" : (meta.robots || "index, follow");
    const schemaItems = Array.isArray(typeof jsonLd !== "undefined" ? jsonLd : []) ? jsonLd : [];
    const schemaPayload = schemaItems.length === 1 ? schemaItems[0] : schemaItems;
    const safeSchema = JSON.stringify(schemaPayload).replace(/</g, "\\u003c");
  %>
  <meta charset="UTF-8">
  <title><%= metaTitle %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= metaDescription %>">
  <meta name="robots" content="<%= metaRobots %>">
  <% if (meta.keywords) { %>
    <meta name="keywords" content="<%= meta.keywords %>">
  <% } %>
  <% if (meta.canonicalUrl) { %>
    <link rel="canonical" href="<%= meta.canonicalUrl %>">
  <% } %>
  <meta name="theme-color" content="#171814">
  <meta property="og:site_name" content="<%= meta.siteName || 'ImperialPaws Pekingese' %>">
  <meta property="og:title" content="<%= metaTitle %>">
  <meta property="og:description" content="<%= metaDescription %>">
  <meta property="og:type" content="<%= meta.type || 'website' %>">
  <% if (meta.canonicalUrl) { %>
    <meta property="og:url" content="<%= meta.canonicalUrl %>">
  <% } %>
  <% if (meta.image) { %>
    <meta property="og:image" content="<%= meta.image %>">
    <meta name="twitter:image" content="<%= meta.image %>">
  <% } %>
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= metaTitle %>">
  <meta name="twitter:description" content="<%= metaDescription %>">
  <link rel="preconnect" href="https://res.cloudinary.com">
  <% if (!isAdminPage && typeof currentPath !== "undefined" && currentPath === "/") { %>
    <link rel="preload" href="/images/hero-pekingese.jpg" as="image">
  <% } %>

  <% if (isAdminPage) { %>
    <link rel="stylesheet" href="/css/admin.css">
  <% } else { %>
    <%
      const routePath = typeof currentPath !== "undefined" ? currentPath : "";
      const publicCss = ["/css/main.css", "/css/header.css", "/css/footer.css", "/css/sub-pages.css"];

      if (routePath === "/") {
        publicCss.push("/css/home-index.css", "/css/home-featured.css", "/css/testimonials-lux.css");
      } else if (routePath === "/puppies") {
        publicCss.push("/css/puppies.css");
      } else if (routePath.startsWith("/puppies/")) {
        publicCss.push("/css/puppy-details.css");
      } else if (routePath.startsWith("/testimonials")) {
        publicCss.push("/css/testimonials-lux.css");
      } else if (routePath === "/about") {
        publicCss.push("/css/about.css");
      } else if (routePath === "/adoption-process") {
        publicCss.push("/css/adoption-process.css");
      }
    %>
    <% publicCss.forEach(cssFile => { %>
      <link rel="stylesheet" href="<%= cssFile %>">
    <% }) %>
  <% } %>

  <% if (schemaItems.length && !isAdminPage) { %>
    <script type="application/ld+json"><%- safeSchema %></script>
  <% } %>
</head>

<body class="<%= typeof pageClass !== 'undefined' ? pageClass : '' %><%= isAdminPage ? ' admin-body' : '' %>">
  <% if (!isAdminPage) { %>
    <%- include("../partials/header") %>
  <% } %>

  <main class="<%= isAdminPage ? 'admin-root' : 'main-content' %>">
    <%- body %>
  </main>

  <% if (!isAdminPage) { %>
    <%- include("../partials/footer") %>
  <% } %>

  <% if (!isAdminPage) { %>
    <script src="/js/header.js" defer></script>
    <script src="/js/site.js" defer></script>
    <% if (typeof currentPath !== "undefined" && currentPath.startsWith("/puppies/")) { %>
      <script src="/js/puppy-gallery.js" defer></script>
    <% } %>
  <% } %>
</body>
</html>
