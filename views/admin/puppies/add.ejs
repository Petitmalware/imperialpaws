<div class="admin-shell">
  <%- include("../../partials/admin-sidebar", { active: "puppies" }) %>

  <main class="admin-content">
    <header class="admin-page-header">
      <div>
        <p class="admin-eyebrow">Listings</p>
        <h1>Add Puppy</h1>
        <p class="admin-subtitle">Create the puppy profile first, then upload one or more gallery photos.</p>
      </div>
      <a href="/admin/puppies" class="btn-secondary">Back to Puppies</a>
    </header>

    <form method="POST" action="/admin/puppies/add" class="admin-form-wide">
      <section class="admin-grid two">
        <div class="admin-card">
          <h2>Basic Information</h2>

          <div class="form-grid">
            <div class="form-group">
              <label>Name *</label>
              <input type="text" name="name" required>
            </div>

            <div class="form-group">
              <label>Breed</label>
              <input type="text" name="breed" value="Pekingese">
            </div>

            <div class="form-group">
              <label>Gender</label>
              <select name="gender">
                <option value="">Select gender</option>
                <option value="Male">Male</option>
                <option value="Female">Female</option>
              </select>
            </div>

            <div class="form-group">
              <label>Color</label>
              <input type="text" name="color">
            </div>

            <div class="form-group">
              <label>Date of Birth</label>
              <input type="date" name="dob">
            </div>

            <div class="form-group">
              <label>Status</label>
              <select name="status">
                <option value="Available">Available</option>
                <option value="Reserved">Reserved</option>
                <option value="Sold">Sold</option>
              </select>
            </div>
          </div>

          <div class="form-group checkbox">
            <label>
              <input type="checkbox" name="featured">
              Featured listing
            </label>
          </div>
        </div>

        <div class="admin-card">
          <h2>Pricing</h2>

          <div class="form-grid">
            <div class="form-group">
              <label>Price</label>
              <input type="number" step="0.01" min="0" name="price">
            </div>

            <div class="form-group">
              <label>Currency</label>
              <select name="currency">
                <option value="USD">USD</option>
                <option value="CAD">CAD</option>
                <option value="EUR">EUR</option>
                <option value="GBP">GBP</option>
              </select>
            </div>
          </div>

          <p class="admin-muted">Invoices can later use this price as the default adoption fee.</p>
        </div>
      </section>

      <section class="admin-grid two">
        <div class="admin-card">
          <h2>Health</h2>

          <div class="form-group checkbox">
            <label>
              <input type="checkbox" name="vetChecked">
              Vet checked
            </label>
          </div>

          <div class="form-group">
            <label>Vaccination Status</label>
            <input type="text" name="vaccinationStatus" placeholder="Current on age-appropriate vaccinations">
          </div>
        </div>

        <div class="admin-card">
          <h2>Registration</h2>

          <div class="form-group">
            <label>Registration Type</label>
            <input type="text" name="registrationType">
          </div>

          <div class="form-group">
            <label>Registration Notes</label>
            <textarea name="registrationNotes" rows="4"></textarea>
          </div>
        </div>
      </section>

      <section class="admin-card">
        <h2>Parents</h2>

        <div class="form-grid">
          <div class="form-group">
            <label>Sire Name</label>
            <input type="text" name="sireName">
          </div>

          <div class="form-group">
            <label>Dam Name</label>
            <input type="text" name="damName">
          </div>
        </div>
      </section>

      <section class="admin-card">
        <h2>Description</h2>
        <div class="form-group">
          <label>Public Description</label>
          <textarea name="description" rows="5" placeholder="Describe temperament, personality, and important adoption details."></textarea>
        </div>
      </section>

      <div class="admin-actions">
        <button type="submit" class="btn-primary">Save Puppy</button>
        <a href="/admin/puppies" class="btn-secondary">Cancel</a>
      </div>
    </form>
  </main>
</div>
