<div class="admin-shell">
  <%- include("../../partials/admin-sidebar", { active: "puppies" }) %>

  <main class="admin-content">
    <header class="admin-page-header">
      <div>
        <p class="admin-eyebrow">Listings</p>
        <h1>Puppies</h1>
        <p class="admin-subtitle">Create listings, update availability, and manage each puppy gallery.</p>
      </div>
      <a href="/admin/puppies/add" class="admin-link-button">Add Puppy</a>
    </header>

    <% if (!puppies || !puppies.length) { %>
      <section class="admin-empty-state">
        <strong>No puppies added yet.</strong>
        <p class="admin-muted">Create the first puppy listing to begin accepting applications.</p>
      </section>
    <% } else { %>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Status</th>
              <th>Featured</th>
              <th>Photos</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% puppies.forEach(puppy => { %>
              <tr>
                <td><strong><%= puppy.name %></strong></td>
                <td><span class="status-pill <%= statusClass(puppy.status || 'Available') %>"><%= puppy.status || "Available" %></span></td>
                <td><%= puppy.featured ? "Yes" : "No" %></td>
                <td><%= puppy.images && puppy.images.length ? puppy.images.length : 0 %></td>
                <td class="admin-actions">
                  <a class="btn-small" href="/admin/puppies/edit?id=<%= puppy.id %>">Edit</a>
                  <a class="btn-small" href="/admin/puppies/images?id=<%= puppy.id %>">Photos</a>
                  <form action="/admin/puppies/delete" method="POST" onsubmit="return confirm('Delete this puppy?');">
                    <input type="hidden" name="id" value="<%= puppy.id %>">
                    <button type="submit" class="btn-danger">Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </main>
</div>
