<div class="admin-shell">
  <%- include("../partials/admin-sidebar", { active: "settings" }) %>

  <main class="admin-content">
    <header class="admin-page-header">
      <div>
        <p class="admin-eyebrow">Configuration</p>
        <h1>Site Settings</h1>
        <p class="admin-subtitle">Manage public contact information and social links displayed across the website.</p>
      </div>
    </header>

    <section class="admin-card">
      <form method="POST" action="/admin/settings" class="admin-form">
        <section class="admin-section">
          <h2>Contact Information</h2>
          <div class="form-grid">
            <div class="form-group">
              <label>Email</label>
              <input type="email" name="email" value="<%= settings.contact.email || '' %>">
            </div>
            <div class="form-group">
              <label>Phone</label>
              <input type="text" name="phone" value="<%= settings.contact.phone || '' %>">
            </div>
            <div class="form-group">
              <label>Location</label>
              <input type="text" name="location" value="<%= settings.contact.location || '' %>">
            </div>
          </div>
        </section>

        <section class="admin-section">
          <h2>Social Links</h2>
          <div class="form-grid">
            <div class="form-group">
              <label>Facebook URL</label>
              <input type="text" name="facebook" value="<%= settings.socials.facebook || '' %>">
            </div>
            <div class="form-group">
              <label>Instagram URL</label>
              <input type="text" name="instagram" value="<%= settings.socials.instagram || '' %>">
            </div>
            <div class="form-group">
              <label>Twitter / X URL</label>
              <input type="text" name="twitter" value="<%= settings.socials.twitter || '' %>">
            </div>
            <div class="form-group">
              <label>TikTok URL</label>
              <input type="text" name="tiktok" value="<%= settings.socials.tiktok || '' %>">
            </div>
          </div>
        </section>

        <section class="admin-section">
          <h2>SEO & Trust Signals</h2>
          <p class="admin-muted">
            These values control search snippets, social previews, canonical URLs, and the public business schema.
          </p>
          <div class="form-grid">
            <div class="form-group">
              <label>Site Name</label>
              <input type="text" name="siteName" value="<%= settings.meta.siteName || 'ImperialPaws Pekingese' %>">
            </div>
            <div class="form-group">
              <label>Public Site URL</label>
              <input type="url" name="siteUrl" value="<%= settings.meta.siteUrl || '' %>" placeholder="https://imperialpaws-pekingese.onrender.com">
            </div>
            <div class="form-group">
              <label>SEO Title</label>
              <input type="text" name="metaTitle" value="<%= settings.meta.title || 'ImperialPaws Pekingese' %>">
            </div>
            <div class="form-group">
              <label>Share Image</label>
              <input type="text" name="metaImage" value="<%= settings.meta.image || '/images/hero-pekingese.jpg' %>" placeholder="/images/hero-pekingese.jpg">
            </div>
          </div>

          <div class="form-group">
            <label>Meta Description</label>
            <textarea name="metaDescription"><%= settings.meta.description || '' %></textarea>
          </div>

          <div class="form-group">
            <label>Search Keywords</label>
            <textarea name="metaKeywords"><%= settings.meta.keywords || '' %></textarea>
          </div>
        </section>

        <div class="admin-actions">
          <button type="submit" class="btn-primary">Save Settings</button>
          <% if (settings.meta && settings.meta.lastUpdated) { %>
            <span class="admin-muted">Last updated <%= new Date(settings.meta.lastUpdated).toLocaleString() %></span>
          <% } %>
        </div>
      </form>
    </section>
  </main>
</div>
