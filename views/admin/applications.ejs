<div class="admin-shell">
  <%- include("../partials/admin-sidebar", { active: "applications" }) %>

  <main class="admin-content">
    <header class="admin-page-header">
      <div>
        <p class="admin-eyebrow">Adoptions</p>
        <h1>Applications</h1>
        <p class="admin-subtitle">Review buyer applications and keep puppy placement status accurate.</p>
      </div>
    </header>

    <% if (applications.length === 0) { %>
      <section class="admin-empty-state">
        <strong>No applications submitted yet.</strong>
        <p class="admin-muted">New buyer applications will appear here.</p>
      </section>
    <% } else { %>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Tracking Code</th>
              <th>Puppy</th>
              <th>Applicant</th>
              <th>Email</th>
              <th>Status</th>
              <th>Submitted</th>
            </tr>
          </thead>

          <tbody>
            <% applications.forEach(app => { %>
              <tr>
                <td class="mono"><%= app.id %></td>
                <td><%= app.puppyName %></td>
                <td><%= app.name %></td>
                <td><%= app.email %></td>
                <td>
                  <span class="status-pill <%= statusClass(app.status) %>">
                    <%= app.status %>
                  </span>

                  <form method="post" action="/admin/applications/<%= app.id %>/status" class="status-form">
                    <select name="status" required>
                      <option value="">Change status</option>
                      <option value="Pending">Mark Pending</option>
                      <option value="Approved">Approve</option>
                      <option value="Rejected">Reject</option>
                      <option value="Sold">Mark Sold</option>
                    </select>
                    <button type="submit">Update</button>
                  </form>
                </td>
                <td><%= app.createdAt ? new Date(app.createdAt).toLocaleDateString() : "Unknown" %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </main>
</div>
