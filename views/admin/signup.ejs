<section class="admin-login">
  <div class="admin-login-card">
    <div class="admin-logo admin-login-brand">
      <span class="admin-mark">IP</span>
      <div>
        <strong>ImperialPaws</strong>
        <em>Admin Setup</em>
      </div>
    </div>

    <h1>Create Admin Account</h1>
    <p class="admin-subtitle">Complete the invited administrator account before entering the dashboard.</p>

    <form method="post" action="/admin/admins/signup" class="admin-form">
      <input type="hidden" name="email" value="<%= email %>">
      <input type="hidden" name="code" value="<%= code %>">

      <div class="form-group">
        <label>Email</label>
        <input type="email" value="<%= email %>" disabled>
      </div>

      <div class="form-group">
        <label>Create Password</label>
        <input type="password" name="password" minlength="8" required>
      </div>

      <button type="submit" class="btn-primary">Create Account</button>
    </form>
  </div>
</section>
