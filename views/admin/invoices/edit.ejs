<div class="admin-shell">
  <%- include("../../partials/admin-sidebar", { active: "invoices" }) %>

  <main class="admin-content">
    <header class="admin-page-header">
      <div>
        <p class="admin-eyebrow">Invoices</p>
        <h1>Edit Invoice</h1>
        <p class="admin-subtitle">Update invoice <strong><%= invoice.invoiceNumber %></strong>.</p>
      </div>
      <a href="/admin/invoices" class="btn-secondary">Back to Invoices</a>
    </header>

    <form method="POST" action="/admin/invoices/edit/<%= invoice.invoiceNumber %>" class="admin-form-wide">
      <section class="admin-grid two">
        <div class="admin-card">
          <h2>Seller</h2>
          <div class="form-group"><label>Name</label><input name="sellerName" value="<%= invoice.seller?.name || '' %>"></div>
          <div class="form-group"><label>Address</label><input name="sellerAddress" value="<%= invoice.seller?.address || '' %>"></div>
          <div class="form-grid">
            <div class="form-group"><label>Phone</label><input name="sellerPhone" value="<%= invoice.seller?.phone || '' %>"></div>
            <div class="form-group"><label>Email</label><input name="sellerEmail" value="<%= invoice.seller?.email || '' %>"></div>
          </div>
          <div class="form-group"><label>Website</label><input name="sellerWebsite" value="<%= invoice.seller?.website || '' %>"></div>
        </div>

        <div class="admin-card">
          <h2>Adopting Parent</h2>
          <div class="form-group"><label>Name</label><input name="parentName" value="<%= invoice.adoptingParent?.name || '' %>"></div>
          <div class="form-grid">
            <div class="form-group"><label>Phone</label><input name="parentPhone" value="<%= invoice.adoptingParent?.phone || '' %>"></div>
            <div class="form-group"><label>Email</label><input name="parentEmail" value="<%= invoice.adoptingParent?.email || '' %>"></div>
          </div>
          <div class="form-group"><label>Address</label><input name="parentAddress" value="<%= invoice.adoptingParent?.address || '' %>"></div>
          <div class="form-grid">
            <div class="form-group"><label>City</label><input name="parentCity" value="<%= invoice.adoptingParent?.city || '' %>"></div>
            <div class="form-group"><label>State</label><input name="parentState" value="<%= invoice.adoptingParent?.state || '' %>"></div>
            <div class="form-group"><label>ZIP</label><input name="parentZip" value="<%= invoice.adoptingParent?.zip || '' %>"></div>
          </div>
        </div>
      </section>

      <section class="admin-card">
        <h2>Invoice Details</h2>
        <div class="form-grid">
          <div class="form-group"><label>Issue Date</label><input type="date" name="issueDate" value="<%= invoice.issueDate || '' %>"></div>
          <div class="form-group"><label>Due Date</label><input type="date" name="dueDate" value="<%= invoice.dueDate || '' %>"></div>
          <div class="form-group">
            <label>Currency</label>
            <select name="currency">
              <option value="$" <%= invoice.currency === "$" ? "selected" : "" %>>$ USD</option>
              <option value="&euro;" <%= invoice.currency === "\u20ac" || invoice.currency === "&euro;" ? "selected" : "" %>>&euro; EUR</option>
              <option value="&pound;" <%= invoice.currency === "\u00a3" || invoice.currency === "&pound;" ? "selected" : "" %>>&pound; GBP</option>
            </select>
          </div>
        </div>

        <div class="form-grid">
          <div class="form-group"><label>Line Item</label><input name="itemDescription" value="<%= invoice.items?.[0]?.description || '' %>"></div>
          <div class="form-group"><label>Quantity</label><input type="number" name="itemQty" value="<%= invoice.items?.[0]?.qty || 1 %>"></div>
          <div class="form-group"><label>Price</label><input type="number" step="0.01" name="itemPrice" value="<%= invoice.items?.[0]?.unitPrice || 0 %>"></div>
          <div class="form-group"><label>Tax Rate</label><input type="number" step="0.01" name="taxRate" value="<%= invoice.taxRate || 0 %>"></div>
        </div>

        <div class="form-group">
          <label>Adoption Note</label>
          <textarea name="notes"><%= invoice.notes || '' %></textarea>
        </div>
      </section>

      <div class="admin-actions">
        <button class="btn-primary" type="submit">Save Changes</button>
        <a href="/admin/invoices" class="btn-secondary">Cancel</a>
      </div>
    </form>
  </main>
</div>
