<div class="admin-shell">
  <%- include("../../partials/admin-sidebar", { active: "invoices" }) %>

  <main class="admin-content">
    <header class="admin-page-header">
      <div>
        <p class="admin-eyebrow">Invoices</p>
        <h1>Create Invoice</h1>
        <p class="admin-subtitle">Invoice for <strong><%= application.name %></strong><% if (puppy) { %> adopting <strong><%= puppy.name %></strong><% } %>.</p>
      </div>
      <a href="/admin/invoices/select-application" class="btn-secondary">Change Application</a>
    </header>

    <form method="POST" action="/admin/invoices/add" class="admin-form-wide">
      <input type="hidden" name="applicationId" value="<%= application.id %>">
      <input type="hidden" name="puppyId" value="<%= puppy?.id || '' %>">

      <section class="admin-grid two">
        <div class="admin-card">
          <h2>Seller</h2>
          <div class="form-group">
            <label>Business Name</label>
            <input name="sellerName" value="ImperialPaws Pekingese">
          </div>
          <div class="form-group">
            <label>Address</label>
            <input name="sellerAddress" value="<%= settings.contact.location || '' %>">
          </div>
          <div class="form-grid">
            <div class="form-group">
              <label>Phone</label>
              <input name="sellerPhone" value="<%= settings.contact.phone || '' %>">
            </div>
            <div class="form-group">
              <label>Email</label>
              <input name="sellerEmail" value="<%= settings.contact.email || '' %>">
            </div>
          </div>
          <div class="form-group">
            <label>Website</label>
            <input name="sellerWebsite">
          </div>
        </div>

        <div class="admin-card">
          <h2>Adopting Parent</h2>
          <div class="form-group">
            <label>Name</label>
            <input name="parentName" value="<%= application.name %>">
          </div>
          <div class="form-grid">
            <div class="form-group">
              <label>Phone</label>
              <input name="parentPhone" value="<%= application.phone || '' %>">
            </div>
            <div class="form-group">
              <label>Email</label>
              <input name="parentEmail" value="<%= application.email %>">
            </div>
          </div>
          <div class="form-group">
            <label>Address</label>
            <input name="parentAddress">
          </div>
          <div class="form-grid">
            <div class="form-group">
              <label>City</label>
              <input name="parentCity">
            </div>
            <div class="form-group">
              <label>State</label>
              <input name="parentState">
            </div>
            <div class="form-group">
              <label>ZIP / Postal Code</label>
              <input name="parentZip">
            </div>
          </div>
        </div>
      </section>

      <section class="admin-card">
        <h2>Invoice Details</h2>
        <div class="form-grid">
          <div class="form-group">
            <label>Issue Date</label>
            <input name="issueDate" type="date">
          </div>
          <div class="form-group">
            <label>Due Date</label>
            <input name="dueDate" type="date">
          </div>
          <div class="form-group">
            <label>Currency</label>
            <select name="currency">
              <option value="$" <%= puppyCurrency === "$" ? "selected" : "" %>>$ USD / CAD</option>
              <option value="&euro;" <%= puppyCurrency === "\u20ac" ? "selected" : "" %>>&euro; EUR</option>
              <option value="&pound;" <%= puppyCurrency === "\u00a3" ? "selected" : "" %>>&pound; GBP</option>
            </select>
          </div>
        </div>

        <div class="form-grid">
          <div class="form-group">
            <label>Line Item</label>
            <input name="itemDescription" value="<%= puppy ? puppy.name + ' - Puppy Adoption Fee' : 'Puppy Adoption Fee' %>">
          </div>
          <div class="form-group">
            <label>Quantity</label>
            <input name="itemQty" type="number" value="1" min="1">
          </div>
          <div class="form-group">
            <label>Price</label>
            <input name="itemPrice" type="number" step="0.01" min="0" value="<%= puppy?.price || '' %>">
          </div>
          <div class="form-group">
            <label>Tax Rate</label>
            <input name="taxRate" type="number" step="0.01" min="0" placeholder="0.00">
          </div>
        </div>

        <div class="form-group">
          <label>Adoption Note</label>
          <textarea name="notes"><%= defaultInvoiceNote %></textarea>
        </div>
      </section>

      <div class="admin-actions">
        <button class="btn-primary" type="submit">Create Invoice</button>
        <a href="/admin/invoices" class="btn-secondary">Cancel</a>
      </div>
    </form>
  </main>
</div>
