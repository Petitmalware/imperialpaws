<div class="admin-shell">
  <%- include("../../partials/admin-sidebar", { active: "invoices" }) %>

  <main class="admin-content">
    <header class="admin-page-header">
      <div>
        <p class="admin-eyebrow">Invoices</p>
        <h1>Select Application</h1>
        <p class="admin-subtitle">Choose an approved adoption application to generate an invoice.</p>
      </div>
      <a href="/admin/invoices" class="btn-secondary">Back to Invoices</a>
    </header>

    <% if (!applications.length) { %>
      <section class="admin-empty-state">
        <strong>No approved applications yet.</strong>
        <p class="admin-muted">Approve an application before creating an invoice.</p>
      </section>
    <% } else { %>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Applicant</th>
              <th>Email</th>
              <th>Puppy</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% applications.forEach(app => { %>
              <tr>
                <td><strong><%= app.name %></strong></td>
                <td><%= app.email || "No email" %></td>
                <td><%= app.puppyName %></td>
                <td>
                  <a class="admin-link-button" href="/admin/invoices/add/<%= app.id %>">Create Invoice</a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </main>
</div>
