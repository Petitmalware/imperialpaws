<section class="admin-login">
  <div class="admin-login-card">
    <div class="admin-logo admin-login-brand">
      <span class="admin-mark">IP</span>
      <div>
        <strong>ImperialPaws</strong>
        <em>Admin Panel</em>
      </div>
    </div>

    <h1>Admin Login</h1>
    <p class="admin-subtitle">Sign in to manage puppies, applications, reviews, and invoices.</p>

    <% if (error) { %>
      <div class="error-box"><%= error %></div>
    <% } %>

    <form method="POST" action="/admin/login" class="admin-form">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" autocomplete="username" required>
      </div>

      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" autocomplete="current-password" required>
      </div>

      <button class="btn-admin-primary" type="submit">Login</button>
    </form>
  </div>
</section>
