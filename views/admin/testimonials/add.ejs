<div class="admin-shell">
  <%- include("../../partials/admin-sidebar", { active: "testimonials" }) %>

  <main class="admin-content">
    <header class="admin-page-header">
      <div>
        <p class="admin-eyebrow">Reviews</p>
        <h1>Add Testimonial</h1>
        <p class="admin-subtitle">Create a testimonial manually when a buyer sends feedback directly.</p>
      </div>
      <a href="/admin/testimonials" class="btn-secondary">Back to Reviews</a>
    </header>

    <section class="admin-card">
      <% if (typeof error !== "undefined" && error) { %>
        <div class="error-box"><%= error %></div>
      <% } %>

      <form method="post" action="/admin/testimonials/add" class="admin-form">
        <div class="form-grid">
          <div class="form-group">
            <label>Name</label>
            <input type="text" name="name">
          </div>

          <div class="form-group">
            <label>Email</label>
            <input type="email" name="email">
          </div>
        </div>

        <div class="form-group">
          <label>Location</label>
          <input type="text" name="location">
        </div>

        <div class="form-group">
          <label>Experience</label>
          <textarea name="message" rows="5" required></textarea>
        </div>

        <button type="submit" class="btn-primary">Save Testimonial</button>
      </form>
    </section>
  </main>
</div>
