<div class="admin-shell">
  <%- include("../../partials/admin-sidebar", { active: "testimonials" }) %>

  <main class="admin-content">
    <header class="admin-page-header">
      <div>
        <p class="admin-eyebrow">Reviews</p>
        <h1>Testimonials</h1>
        <p class="admin-subtitle">Approve, feature, or remove buyer reviews before they appear publicly.</p>
      </div>
      <a href="/admin/testimonials/add" class="admin-link-button">Add Review</a>
    </header>

    <% if (!testimonials || testimonials.length === 0) { %>
      <section class="admin-empty-state">
        <strong>No testimonials submitted yet.</strong>
        <p class="admin-muted">Public review submissions will appear here for moderation.</p>
      </section>
    <% } else { %>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Message</th>
              <th>Status</th>
              <th>Featured</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody>
            <% testimonials.forEach(testimonial => { %>
              <tr>
                <td>
                  <strong><%= testimonial.name %></strong><br>
                  <small><%= testimonial.location || "" %></small>
                </td>
                <td class="testimonial-message"><%= testimonial.message %></td>
                <td>
                  <span class="status-pill <%= testimonial.approved ? 'approved' : 'pending' %>">
                    <%= testimonial.approved ? "Approved" : "Pending" %>
                  </span>
                </td>
                <td>
                  <span class="status-pill <%= testimonial.featured ? 'featured' : 'neutral' %>">
                    <%= testimonial.featured ? "Yes" : "No" %>
                  </span>
                </td>
                <td class="action-buttons">
                  <form method="post" action="/admin/testimonials/<%= testimonial.id %>/approve">
                    <button class="btn-small" type="submit">
                      <%= testimonial.approved ? "Unapprove" : "Approve" %>
                    </button>
                  </form>

                  <form method="post" action="/admin/testimonials/<%= testimonial.id %>/feature">
                    <button class="btn-small" type="submit">
                      <%= testimonial.featured ? "Unfeature" : "Feature" %>
                    </button>
                  </form>

                  <form method="post" action="/admin/testimonials/<%= testimonial.id %>/delete" onsubmit="return confirm('Delete this testimonial?');">
                    <button class="btn-danger" type="submit">Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </main>
</div>
