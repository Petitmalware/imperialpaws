PORT=3000
NODE_ENV=development
SESSION_SECRET=replace-with-a-long-random-secret

# MongoDB Atlas. Use the mongodb+srv:// string from Atlas and URL-encode
# special password characters, for example $ becomes %24.
MONGODB_URI=mongodb+srv://username:url-encoded-password@cluster.mongodb.net/?appName=imperialpaws
MONGODB_DB=imperialpaws
MONGODB_TIMEOUT_MS=2500
MONGODB_RETRY_COOLDOWN_MS=30000
DATA_STORE_LOCAL_FALLBACK=true
IMAGE_STORAGE_LOCAL_FALLBACK=true

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional for first Mongo migration
OWNER_USERNAME=owner
OWNER_PASSWORD=replace-with-a-strong-owner-password
